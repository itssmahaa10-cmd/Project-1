import re
import random
import string

# Function to check password strength
def evaluate_password(password):
    """
    Evaluates password strength based on length, complexity, and common patterns.
    Returns a score (0-5) and suggestions to improve.
    """
    score = 0
    suggestions = []

    # Check length
    if len(password) >= 12:
        score += 2
    elif len(password) >= 8:
        score += 1
        suggestions.append("Consider using at least 12 characters for stronger security.")
    else:
        suggestions.append("Password is too short. Use at least 8 characters.")

    # Check for lowercase, uppercase, digits, special characters
    if re.search(r'[a-z]', password):
        score += 1
    else:
        suggestions.append("Add lowercase letters.")

    if re.search(r'[A-Z]', password):
        score += 1
    else:
        suggestions.append("Add uppercase letters.")

    if re.search(r'\d', password):
        score += 1
    else:
        suggestions.append("Include numbers.")

    if re.search(r'[!@#$%^&*(),.?":{}|<>]', password):
        score += 1
    else:
        suggestions.append("Include special characters (e.g., !@#$%^&*).")

    # Check for common patterns (optional)
    common_passwords = ["password", "123456", "qwerty", "abc123", "letmein"]
    if password.lower() in common_passwords:
        score = 0
        suggestions.append("Avoid using common passwords.")

    # Final strength label
    if score <= 2:
        strength = "Weak"
    elif score <= 4:
        strength = "Moderate"
    else:
        strength = "Strong"

    return {"score": score, "strength": strength, "suggestions": suggestions}

# Function to generate a stronger password
def generate_strong_password(length=16):
    """
    Generates a random strong password with letters, numbers, and special characters.
    """
    if length < 12:
        length = 12  # Ensure minimum strength

    chars = string.ascii_letters + string.digits + "!@#$%^&*()_+-=[]{}|;:,.<>?"
    password = ''.join(random.choice(chars) for _ in range(length))
    return password

# Example usage
if __name__ == "__main__":
    user_password = input("Enter a password to evaluate: ")
    result = evaluate_password(user_password)
    
    print(f"\nPassword Strength: {result['strength']} (Score: {result['score']}/5)")
    if result['suggestions']:
        print("Suggestions to improve your password:")
        for s in result['suggestions']:
            print(f" - {s}")

    # Optional: suggest a strong alternative
    strong_password = generate_strong_password()
    print(f"\nSuggested Strong Password: {strong_password}")
